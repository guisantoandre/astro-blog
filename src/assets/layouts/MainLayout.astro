---
import "../../styles/global.css";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../constants";
import Header from "../../components/Header.astro";

interface Props {
   title?: string;
   bgColor?: "bg-azul-700" | "bg-azul-800";
   class?: string;
   hasHeader?: boolean;
}

const {
   title = SITE_TITLE,
   bgColor = "bg-azul-900",
   class: className,
   hasHeader = true,
} = Astro.props;
---

<html lang="pt-BR">
   <head>
      <meta charset="utf-8" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="icon" href="/favicon.ico" />
      <meta name="viewport" content="width=device-width" />
      <meta name="description" content={SITE_DESCRIPTION} />
      <title>{`${title} | ${SITE_DESCRIPTION}`}</title>
   </head>
   <body
      class={`${bgColor} text-white font-sans overflow-x-hidden ${className}`}
   >
      {hasHeader && <Header />}
      <slot />
   </body>
</html>

---
interface Props {
   title: string;
   href: string;
   class?: string;
}

const { title, class: className, href } = Astro.props;
---

<a
   href={href}
   class={`inline-block bg-azul-800 hover:bg-azul-800/80 px-12 py-2 uppercase font-semibold rounded-md mb-10 duration-100 ${className}`}
   >{title}</a
>

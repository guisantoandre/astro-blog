---
import { Image } from "astro:assets";
const { post } = Astro.props;
---

<article
   class="relative flex flex-col bg-azul-900/40 border border-white/5 rounded-3xl overflow-hidden hover:border-azul-500/30 transition-all duration-300 group hover:bg-azul-900/60"
>
   <div class="relative overflow-hidden h-52">
      <Image
         src={post.image}
         alt={post.title}
         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
   </div>

   <div class="p-7 flex flex-col flex-1">
      <header>
         <span
            class="text-[10px] tracking-[0.2em] font-bold text-azul-400 uppercase"
         >
            {post.tags.join(" — ")}
         </span>

         <h3
            class="text-2xl font-semibold mt-2 leading-tight group-hover:text-azul-300 transition-colors"
         >
            <a
               href={`/article/${post.slug}`}
               class="after:absolute after:inset-0"
            >
               {post.title}
            </a>
         </h3>
      </header>

      <p class="text-white/60 mt-4 line-clamp-3 text-sm leading-relaxed">
         {post.description}
      </p>

      <footer
         class="mt-auto pt-6 flex items-center justify-between border-t border-white/5"
      >
         <span class="text-xs text-white/30 font-mono">{post.date}</span>
         <span
            class="text-xs font-bold uppercase tracking-widest text-white group-hover:text-azul-400 transition-colors"
         >
            Ler artigo →
         </span>
      </footer>
   </div>
</article>

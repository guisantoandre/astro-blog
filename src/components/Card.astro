---
import { Image } from "astro:assets";
import type { Post } from "../data/posts";

interface Props {
   post: Post;
}

const { post } = Astro.props;
---

<article
   class="relative group flex flex-col p-8 bg-azul-900 rounded-xl border-2 border-azul-700/50 hover:border-azul-700/100 hover:-translate-y-2 transition-transform duration-300"
>
   <div class="overflow-hidden rounded-md mb-2">
      <Image
         src={post.image}
         alt={post.title}
         class="object-cover group-hover:scale-105 duration-150"
         width={550}
         height={360}
      />
   </div>

   <div class="flex flex-col space-y-6 flex-1">
      <div class="flex-1">
         <header>
            <span class="text-sm font-light text-white/50 uppercase">
               {post.tags.join(" — ")}
            </span>
            <h3
               class="text-lg font-semibold font-display leading-relaxed tracking-wide my-2 group-hover:text-azul-300 transition-colors"
            >
               <a
                  href={`/article/${post.slug}`}
                  class="after:absolute after:inset-0"
               >
                  {post.title}
               </a>
            </h3>
         </header>
         <p class="text-white/60 line-clamp-3 text-balance">
            {post.description}
         </p>
      </div>

      <footer class="flex items-center justify-between">
         <span
            class="text-sm text-white/50 group-hover:text-white/100 duration-100"
            >{post.date}</span
         >
         <span
            class="font-serif text-white/50 group-hover:text-white/100 duration-100"
         >
            →
         </span>
      </footer>
   </div>
</article>

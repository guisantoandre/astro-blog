---
import Glow from "./Glow.astro";
import Navbar from "./Navbar.astro";
---

<header
   class="flex flex-wrap gap-8 items-center justify-between py-6 md:py-8 container"
>
   <Glow class="-top-40 left-1/3 -translate-x-1/2 w-250 h-100" opacity={0.18} />
   <img src="/logo.svg" alt="Astroblog Logo" />

   <Navbar />
</header>

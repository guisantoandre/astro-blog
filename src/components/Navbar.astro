---
const links = [
   { name: "Home", href: "/" },
   { name: "Blog", href: "/articles" },
];

const currentPath = Astro.url.pathname;
---

<nav>
   <ul class="flex gap-12">
      {
         links.map((link) => {
            const isActive = link.href === currentPath;

            return (
               <li>
                  <a
                     class={`font-semibold duration-100 ${isActive ? "text-white" : "text-white/70 hover:text-white"}`}
                     href={link.href}
                  >
                     {link.name}
                  </a>
               </li>
            );
         })
      }
   </ul>
</nav>

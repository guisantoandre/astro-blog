---
import "../styles/global.css";
import { Image } from "astro:assets";

import Glow from "../components/Glow.astro";
import Navbar from "../components/Navbar.astro";
import BtnCta from "../components/BtnCta.astro";
import HeroImg from "../assets/images/ui/hero-img.png";
---

<html lang="pt-BR">
   <head>
      <meta charset="utf-8" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="icon" href="/favicon.ico" />
      <meta name="viewport" content="width=device-width" />
      <title>Astroblog | Notícias e artigos sobre tecnologia</title>
   </head>
   <body class="bg-azul-900 text-white font-sans overflow-x-hidden">
      <header class="flex items-center justify-between py-10 container">
         <Glow class="-top-32 left-1/3 -translate-x-1/2 w-250 h-100" />
         <img src="/logo.svg" alt="Astroblog Logo" />

         <Navbar />
      </header>

      <section
         class="relative container flex flex-col items-center md:flex-row md:justify-between pt-6"
      >
         <div class="md:basis-3/5 space-y-4 pb-10">
            <Glow class="left-1/2 -translate-x-1/2 w-250 h-100" />
            <h2
               class="text-4xl md:text-5xl font-semibold font-display leading-tight before:block before:w-20 before:h-0.5 before:bg-gradient before:mb-1 hover:before:w-28 before:duration-100"
            >
               Porque cada bit importa
            </h2>
            <p class="text-lg text-white/70 max-w-2xl">
               Acompanhe os movimentos que moldam o futuro em artigos curtos,
               precisos e feitos para mentes curiosas.
            </p>
            <BtnCta title="Explorar" class="mt-12" />
         </div>

         <div class="md:basis-2/5 md:self-end">
            <img
               src="/polygon.svg"
               alt="Polígono de fundo"
               class="absolute -z-10 w-110 md:w-150 md:-translate-y-4 md:-translate-x-10 animate-spin [animation-duration:60s]"
            />
            <Image
               src={HeroImg}
               alt="Astroblog Hero Image"
               class="mx-auto w-1/2 md:translate-x-5 md:w-full"
            />
         </div>
      </section>

      <main class="bg-azul-800 rounded-tl-4xl rounded-tr-4xl min-h-80">
         <h1 class="text-5xl font-display text-center pt-20">Posts</h1>
      </main>
   </body>
</html>

---
import { Image } from "astro:assets";

import MainLayout from "../assets/layouts/MainLayout.astro";
import Glow from "../components/Glow.astro";
import Navbar from "../components/Navbar.astro";
import BtnCta from "../components/BtnCta.astro";
import HeroImg from "../assets/images/ui/hero-img.png";
import Cards from "../components/Cards.astro";
---

<MainLayout>
   <header class="flex items-center justify-between py-10 container">
      <Glow
         class="-top-40 left-1/3 -translate-x-1/2 w-250 h-100"
         opacity={0.18}
      />
      <img src="/logo.svg" alt="Astroblog Logo" />

      <Navbar />
   </header>

   <!-- HERO SECTION -->
   <section
      class="relative container pt-10 md:pt-6 flex flex-col md:flex-row items-center md:justify-between"
   >
      <div
         class="space-y-2 pb-10 md:pb-14 text-center md:text-left md:basis-3/5"
      >
         <Glow class="left-1/2 -translate-x-1/2 w-250 h-100" />
         <h2
            class="text-title before:block before:mx-auto md:before:mx-0 before:w-20 before:h-0.5 before:bg-gradient before:mb-1 hover:before:w-28 before:duration-100"
         >
            Porque cada bit importa
         </h2>
         <p class="text-lg text-white/80 max-w-2xl">
            Acompanhe os movimentos que moldam o futuro através de artigos
            curtos e precisos, escritos para mentes curiosas que buscam entender
            as transformações do nosso tempo em cada detalhe.
         </p>
         <BtnCta title="Explorar" class="mt-7 md:mt-10" />
      </div>

      <div class="md:basis-2/5 md:self-end">
         <img
            src="/polygon.svg"
            alt="Polígono de fundo"
            class="absolute -z-10 w-110 md:w-150 md:-translate-y-4 md:-translate-x-10 animate-spin [animation-duration:60s]"
         />
         <Image
            src={HeroImg}
            alt="Astroblog Hero Image"
            class="mx-auto w-1/2 md:w-full md:translate-x-5"
         />
      </div>
   </section>

   <!-- POSTS SECTION -->
   <main class="bg-azul-800 rounded-tl-4xl rounded-tr-4xl min-h-80">
      <h1 class="text-title text-center pt-20 mb-10">Posts</h1>

      <Cards />
   </main>
</MainLayout>
